  m_Script: {fileID: 11500000, guid: 8eb9d9fa0ccbe1b4cbcd2a1d889b806b, type: 3}
  m_Name: NinthDayConvo02
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  conversationName: NinthDayMainConversation
  lines:
  - speakerName: Randy
    line: Also, can I run something by you real quick?
  - speakerName: Randy
    line: "That question was rhetorical, I don\u2019t care what your answer is."
  - speakerName: Randy
    line: I've been thinking of getting a timescare. It's like a timeshare, but instead
      of-- huh? No, no, it's not a scam, it's--
  - speakerName: Randy
    line: Wait... Oh. It is a scam, isn't it? Darn it.
  - speakerName: Randy
    line: I'll have to get my deposit back... and dispose of that salesman. He <i>was</i>
      a demon, so I should have known... Don't tell anyone about this, okay? It's...
      humiliating.
  repeatLine:
    speakerName: Randy
    line: Don't you have something else better to do?
