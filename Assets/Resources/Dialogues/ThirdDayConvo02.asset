  m_Script: {fileID: 11500000, guid: 8eb9d9fa0ccbe1b4cbcd2a1d889b806b, type: 3}
  m_Name: ThirdDayConvo02
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  conversationName: ThirdDayMainConversation
  lines:
  - speakerName: Randy
    line: "Blood\u2019s been in <i>very</i> high demand lately. Fresh, clean, and
      properly collected, it sells well-- so don\u2019t mess it up. Though I won\u2019t
      hold my breath."
  - speakerName: Randy
    line: "Here is a <b>room key</b>, so you can get started right away. And while
      you\u2019re in there, if you see what looks like tufts of werewolf fur..."
  - speakerName: Randy
    line: "It\u2019s, uh... from the carpets or something. Yeah. They shed a lot
      this time of year."
  repeatLine:
    speakerName: Randy
    line: Don't you have something else better to do?
