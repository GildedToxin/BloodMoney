  m_Script: {fileID: 11500000, guid: 8eb9d9fa0ccbe1b4cbcd2a1d889b806b, type: 3}
  m_Name: SixthDayConvo02
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  conversationName: SixthDayMainConversation
  lines:
  - speakerName: Randy
    line: "Yes, congratulations-- you\u2019ve unlocked a new way to take people apart.
      I\u2019m so proud. Well, not really-- but I might be if you make more money."
  - speakerName: Randy
    line: This is the final tool I will be giving you, so now just focus on the mastery
      of all of them.
  - speakerName: Randy
    line: "Now, take this <b>room key</b> and get \u2018collelling\u2019-- that\u2019s
      collecting and selling. Clever, isn\u2019t it? I came up with it this morning."
  repeatLine:
    speakerName: Randy
    line: Don't you have something else better to do?
